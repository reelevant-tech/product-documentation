{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Reelevant Documentation",
  "colors": {
    "primary": "#EEFF00",
    "light": "#F6F6F6",
    "dark": "#000000"
  },
  "fonts": {
    "family": "Switzer",
    "weight": 400,
    "source": "/fonts/Switzer-Regular.woff2",
    "format": "woff2",
    "heading": {
      "family": "Instrument Serif",
      "weight": 400,
      "source": "/fonts/InstrumentSerif-Regular.woff2",
      "format": "woff2"
    }
  },
  "background": {
    "color": {
      "light": "#F6F6F6",
      "dark": "#000000"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.png",
  "api": {
    "baseUrl": "https://api.reelevant.com/v2"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Platform Guide",
            "pages": [
              "platform-guide/introduction",
              {
                "group": "Workflows",
                "pages": [
                  "platform-guide/workflows/overview",
                  "platform-guide/workflows/creating-a-workflow",
                  "platform-guide/workflows/editor",
                  "platform-guide/workflows/channels",
                  "platform-guide/workflows/data-nodes",
                  "platform-guide/workflows/logic-nodes",
                  "platform-guide/workflows/output-nodes",
                  "platform-guide/workflows/branches",
                  "platform-guide/workflows/versions",
                  "platform-guide/workflows/integration",
                  "platform-guide/workflows/settings"
                ]
              }
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Transformations",
            "pages": [
              "api-reference/transformations/introduction",
              "api-reference/transformations/usage",
              "api-reference/transformations/list",
              {
                "group": "Strings",
                "pages": [
                  "api-reference/transformations/truncate",
                  "api-reference/transformations/case",
                  "api-reference/transformations/replace",
                  "api-reference/transformations/replace-variable",
                  "api-reference/transformations/split",
                  "api-reference/transformations/extract",
                  "api-reference/transformations/template",
                  "api-reference/transformations/length",
                  "api-reference/transformations/pad",
                  "api-reference/transformations/create-hash",
                  "api-reference/transformations/aes-decrypt"
                ]
              },
              {
                "group": "Numbers",
                "pages": [
                  "api-reference/transformations/parse-number",
                  "api-reference/transformations/format-number",
                  "api-reference/transformations/format-currency",
                  "api-reference/transformations/format-currency-locale",
                  "api-reference/transformations/format-currency-locale-currency",
                  "api-reference/transformations/percentage",
                  "api-reference/transformations/absolute",
                  "api-reference/transformations/round"
                ]
              },
              {
                "group": "Maths",
                "pages": [
                  "api-reference/transformations/divide",
                  "api-reference/transformations/multiply",
                  "api-reference/transformations/subtract",
                  "api-reference/transformations/sum",
                  "api-reference/transformations/aggregate-numbers"
                ]
              },
              {
                "group": "Dates",
                "pages": [
                  "api-reference/transformations/format-date",
                  "api-reference/transformations/format-date-locale-var",
                  "api-reference/transformations/parse-date",
                  "api-reference/transformations/difference-between-dates",
                  "api-reference/transformations/add-to-date",
                  "api-reference/transformations/subtract-to-date",
                  "api-reference/transformations/get-date-occurrence"
                ]
              },
              {
                "group": "Arrays",
                "pages": [
                  "api-reference/transformations/array-get",
                  "api-reference/transformations/array-get-var",
                  "api-reference/transformations/array-intersection",
                  "api-reference/transformations/array-unique-rank",
                  "api-reference/transformations/array-unique",
                  "api-reference/transformations/array-concat"
                ]
              },
              {
                "group": "Records",
                "pages": [
                  "api-reference/transformations/lookup"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Datasources API",
        "openapi": "api-reference/openapi/datasources-api.json"
      },
      {
        "tab": "Contents API",
        "openapi": "https://openapi.production.reelevant.io/v1/render/contents-api"
      },
      {
        "tab": "Workflow API",
        "openapi": "https://openapi.production.reelevant.io/v1/render/workflow-api"
      },
      {
        "tab": "Loop API",
        "openapi": "https://openapi.production.reelevant.io/v1/render/loop"
      },
      {
        "tab": "Datasources Collector",
        "openapi": "https://openapi.production.reelevant.io/v1/render/datasources-collector"
      }
    ]
  },
  "global": {
    "anchors": [
      {
        "anchor": "Website",
        "href": "https://reelevant.com",
        "icon": "globe"
      },
      {
        "anchor": "Blog",
        "href": "https://blog.reelevant.com",
        "icon": "newspaper"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://reelevant.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://reelevant.com"
      },
      {
        "label": "Support",
        "href": "mailto:support@reelevant.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.reelevant.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://fr.linkedin.com/company/reelevant"
    }
  }
}
